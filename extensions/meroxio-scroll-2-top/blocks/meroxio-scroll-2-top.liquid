<style>
  /* Scroll to Top Button Styling */
  #scrollTopBtn {
      position: fixed;
      bottom: -50px; /* Start off-screen */
      background-color: {{ block.settings.bgcolor }};
      color: white;
      border: none;
      padding: 17px 20px;
      font-size: 20px;
      cursor: pointer;
      box-shadow: 0 8px 15px rgba(0, 0, 0, 0.2);
      opacity: 0;
      visibility: hidden;
      transition: bottom 0.4s ease, opacity 0.4s ease, visibility 0.4s ease, right 0.4s ease, left 0.4s ease;
      
      {% if block.settings.position == "left" %}
        left: 20px;
      {% else %}
        right: 20px;
      {% endif %}
      
      {% if block.settings.shape == "square" %}
        border-radius: 10px;
      {% else %}
        border-radius: 50%;
      {% endif %}
  }

  /* Hover effect */
  #scrollTopBtn:hover {
      background-color: {{ block.settings.hovercolor }};
      transform: scale(1.1);
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
  }

  /* Show button with smooth animation */
  #scrollTopBtn.show {
      bottom: 20px; /* Move up */
      opacity: 1;
      visibility: visible;
  }
</style>

{% if template != 'index' or block.settings.show_on_home_page %}
  {% if template != 'product' or block.settings.show_on_product_page %}
    {% if template != 'collection' or block.settings.show_on_collection_page %}
      {% if template != 'page' or block.settings.show_on_pages %}
        <button id="scrollTopBtn" onclick="scrollToTop()">

          <svg id="Layer_1" data-name="Layer 1" fill="{{ block.settings.iconcolor }}" height="30px" width="30px" version="1.1"  xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16">
          <title>Trade_Icons</title><polygon points="12.65 11.24 8.46 7.05 4.27 11.24 2.75 9.71 8.46 4 14.17 9.71 12.65 11.24"/></svg>
        </button>
      {% endif %}
    {% endif %}
  {% endif %}
{% endif %}

<script>
    let scrollBtn = document.getElementById("scrollTopBtn");

    window.addEventListener("scroll", function () {
        if (window.scrollY > 100) {
            scrollBtn.classList.add("show"); // Animate & show
        } else {
            scrollBtn.classList.remove("show"); // Hide smoothly
        }
    });

    function scrollToTop() {
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }
</script>

{% schema %}
{
  "name": "Scroll-2-Top",
  "target": "body",
  "settings": [
    {
      "type": "color",
      "id": "bgcolor",
      "label": "Button Background Color",
      "default": "#007bff"
    },
    {
      "type": "color",
      "id": "hovercolor",
      "label": "Button Hover Color",
      "default": "#0000FF"
    },
    {
      "type": "color",
      "id": "iconcolor",
      "label": "Button Icon Color",
      "default": "#000000"
    },
    {
      "type": "checkbox",
      "id": "show_on_home_page",
      "label": "Show on Home Page",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_product_page",
      "label": "Show on Product Page",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_collection_page",
      "label": "Show on Collection Page",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_pages",
      "label": "Show on Pages",
      "default": true
    },
    {
      "type": "select",
      "id": "shape",
      "label": "Button Shape",
      "options": [
        { "value": "circle", "label": "Circle" },
        { "value": "square", "label": "Square" }
      ],
      "default": "circle"
    },
    {
      "type": "select",
      "id": "position",
      "label": "Button Position",
      "options": [
        { "value": "right", "label": "Right" },
        { "value": "left", "label": "Left" }
      ],
      "default": "right"
    }
  ]
}
{% endschema %}

