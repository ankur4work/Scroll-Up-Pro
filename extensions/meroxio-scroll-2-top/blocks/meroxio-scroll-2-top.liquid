<style>
  /* Default Scroll to Top Button Styling */
  #scrollTopBtn {
    position: fixed;
    bottom: -50px; /* Start off-screen */
    right: 20px;
    background-color: #28A745; /* Default (free plan) */
    color: white;
    border: none;
    padding: 11px 15px;
    font-size: 20px;
    cursor: pointer;
    box-shadow: 0 8px 15px rgba(0, 0, 0, 0.2);
    opacity: 0;
    visibility: hidden;
    transition: bottom 0.4s ease, opacity 0.4s ease, visibility 0.4s ease;
    border-radius: 50%;
    display: none; /* Hidden by default */
  }

  #scrollTopBtn:hover {
    background-color: #1C7530;
  }

  #scrollTopBtn.show {
    bottom: 20px;
    opacity: 1;
    visibility: visible;
  }
</style>

<!-- Scroll Button -->
<button id="scrollTopBtn" onclick="scrollToTop()">
  <svg fill="white" height="30px" width="30px"
    xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16">
    <polygon points="12.65 11.24 8.46 7.05 4.27 11.24 2.75 9.71 8.46 4 14.17 9.71 12.65 11.24" />
  </svg>
</button>

<script>
document.addEventListener('DOMContentLoaded', async () => {
  const scrollBtn = document.querySelector("#scrollTopBtn");
  const scrollSvg = scrollBtn.querySelector("svg");
  let plan = "free";

  try {
    const shopUrl = "{{ shop.url }}";
    const shop = shopUrl.replace(/^https?:\/\//, "");
    const res = await fetch(`/apps/scroll-to-top/hasSubscription?shop=${shop}`, {
      method: "GET",
      headers: { "Content-Type": "application/json" },
    });
    if (res.ok) {
      const data = await res.json();
      if (data && data.tier) plan = data.tier;
    }
  } catch (err) {
    console.warn("⚠️ Subscription check failed, defaulting to free:", err);
  }

  console.log("🎯 Final plan detected:", plan);

  /* ---------------- FREE PLAN ---------------- */
  if (plan === "free") {
    {% if template contains 'index' %}
      scrollBtn.style.display = "block";
    {% else %}
      scrollBtn.style.display = "none";
    {% endif %}
  }

  /* ---------------- PREMIUM PLAN ---------------- */
  else if (plan === "premium") {
    {% if template contains 'index' %}
      scrollBtn.style.display = "block";
    {% else %}
      scrollBtn.style.display = "none";
    {% endif %}

    // Apply customization
    scrollBtn.style.backgroundColor = "{{ block.settings.bgcolor }}";
    scrollSvg.style.fill = "{{ block.settings.iconcolor }}";

    scrollBtn.addEventListener("mouseover", () => {
      scrollBtn.style.backgroundColor = "{{ block.settings.hovercolor }}";
    });
    scrollBtn.addEventListener("mouseout", () => {
      scrollBtn.style.backgroundColor = "{{ block.settings.bgcolor }}";
    });

    {% if block.settings.position == "left" %}
      scrollBtn.style.left = "20px";
      scrollBtn.style.right = "auto";
    {% else %}
      scrollBtn.style.right = "20px";
      scrollBtn.style.left = "auto";
    {% endif %}

    {% if block.settings.shape == "square" %}
      scrollBtn.style.borderRadius = "10px";
    {% else %}
      scrollBtn.style.borderRadius = "50%";
    {% endif %}
  }

  /* ---------------- UNLIMITED PLAN ---------------- */
  else if (plan === "unlimited") {
    let show = false;

    {% if block.settings.show_on_home_page %}
      if ("{{ template }}" && "{{ template }}" .includes("index")) show = true;
    {% endif %}
    {% if block.settings.show_on_product_page %}
      if ("{{ template }}" && "{{ template }}" .includes("product")) show = true;
    {% endif %}
    {% if block.settings.show_on_collection_page %}
      if ("{{ template }}" && "{{ template }}" .includes("collection")) show = true;
    {% endif %}
    {% if block.settings.show_on_pages %}
      if ("{{ template }}" && "{{ template }}" .includes("page")) show = true;
    {% endif %}

    if (show) {
      scrollBtn.style.display = "block";
    }

    // Apply customization
    scrollBtn.style.backgroundColor = "{{ block.settings.bgcolor }}";
    scrollSvg.style.fill = "{{ block.settings.iconcolor }}";

    scrollBtn.addEventListener("mouseover", () => {
      scrollBtn.style.backgroundColor = "{{ block.settings.hovercolor }}";
    });
    scrollBtn.addEventListener("mouseout", () => {
      scrollBtn.style.backgroundColor = "{{ block.settings.bgcolor }}";
    });

    {% if block.settings.position == "left" %}
      scrollBtn.style.left = "20px";
      scrollBtn.style.right = "auto";
    {% else %}
      scrollBtn.style.right = "20px";
      scrollBtn.style.left = "auto";
    {% endif %}

    {% if block.settings.shape == "square" %}
      scrollBtn.style.borderRadius = "10px";
    {% else %}
      scrollBtn.style.borderRadius = "50%";
    {% endif %}
  }
});
</script>

<script>
  // Scroll visibility
  const scrollBtn = document.getElementById("scrollTopBtn");
  window.addEventListener("scroll", () => {
    if (window.scrollY > 100) scrollBtn.classList.add("show");
    else scrollBtn.classList.remove("show");
  });

  function scrollToTop() {
    window.scrollTo({ top: 0, behavior: "smooth" });
  }
</script>

{% schema %}
{
  "name": "Scroll-2-Top",
  "target": "body",
  "settings": [
        {
  "type": "header",
  "content": "Plan Information",
"info": "This customization setting is available on Basic and Premium plans. The Scroll to Top button appears on collection, product, and pages only for Premium plan users."
},
    { "type": "color", "id": "bgcolor", "label": "Button Background Color", "default": "#28A745" },
    { "type": "color", "id": "hovercolor", "label": "Button Hover Color", "default": "#1C7530" },
    { "type": "color", "id": "iconcolor", "label": "Button Icon Color", "default": "#FFFFFF" },
    { "type": "checkbox", "id": "show_on_home_page", "label": "Show on Home Page", "default": true },
    { "type": "checkbox", "id": "show_on_product_page", "label": "Show on Product Page", "default": true },
    { "type": "checkbox", "id": "show_on_collection_page", "label": "Show on Collection Page", "default": true },
    { "type": "checkbox", "id": "show_on_pages", "label": "Show on Pages", "default": true },
    {
      "type": "select",
      "id": "shape",
      "label": "Button Shape",
      "options": [
        { "value": "circle", "label": "Circle" },
        { "value": "square", "label": "Square" }
      ],
      "default": "circle"
    },
    {
      "type": "select",
      "id": "position",
      "label": "Button Position",
      "options": [
        { "value": "right", "label": "Right" },
        { "value": "left", "label": "Left" }
      ],
      "default": "right"
    }
  ]
}
{% endschema %}
