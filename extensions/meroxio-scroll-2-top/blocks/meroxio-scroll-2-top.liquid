<style>
  /* Scroll to Top Button Styling */
  #scrollTopBtn {
      position: fixed;
      bottom: -50px; /* Start off-screen */
      right: 20px;
      background-color: {{ block.settings.bgcolor }};
      color: white;
      border: none;
      padding: 17px 20px;
      font-size: 20px;
      border-radius: 50%;
      cursor: pointer;
      box-shadow: 0 8px 15px rgba(0, 0, 0, 0.2);
      opacity: 0;
      visibility: hidden;
      transition: bottom 0.4s ease, opacity 0.4s ease, visibility 0.4s ease;
  }

  /* Hover effect */
  #scrollTopBtn:hover {
      background-color: {{ block.settings.hovercolor }};
      transform: scale(1.1);
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
  }

  /* Show button with smooth animation */
  #scrollTopBtn.show {
      bottom: 20px; /* Move up */
      opacity: 1;
      visibility: visible;
  }
</style>

{% if template != 'product' or block.settings.show_on_product_page %}
  {% if template != 'collection' or block.settings.show_on_collection_page %}
    {% if template != 'page' or block.settings.show_on_pages %}
      <button id="scrollTopBtn" onclick="scrollToTop()">
        <svg fill="{{ block.settings.iconcolor }}" height="20px" width="20px" version="1.1" id="Layer_1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" 
        viewBox="0 0 330 330" xml:space="preserve">
        <path id="XMLID_224_" d="M325.606,229.393l-150.004-150C172.79,76.58,168.974,75,164.996,75c-3.979,0-7.794,1.581-10.607,4.394
        l-149.996,150c-5.858,5.858-5.858,15.355,0,21.213c5.857,5.857,15.355,5.858,21.213,0l139.39-139.393l139.397,139.393
        C307.322,253.536,311.161,255,315,255c3.839,0,7.678-1.464,10.607-4.394C331.464,244.748,331.464,235.251,325.606,229.393z"/>
        </svg>
      </button>
    {% endif %}
  {% endif %}
{% endif %}

<script>
    let scrollBtn = document.getElementById("scrollTopBtn");

    window.addEventListener("scroll", function () {
        if (window.scrollY > 100) {
            scrollBtn.classList.add("show"); // Animate & show
        } else {
            scrollBtn.classList.remove("show"); // Hide smoothly
        }
    });

    function scrollToTop() {
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }
</script>

{% schema %}
{
  "name": "Scroll-2-Top",
  "target": "body",
  "settings": [
    {
      "type": "color",
      "id": "bgcolor",
      "label": "Button Background Color",
      "default": "#007bff"
    },
    {
      "type": "color",
      "id": "hovercolor",
      "label": "Button Hover Color",
      "default": "#0000FF"
    },
    {
      "type": "color",
      "id": "iconcolor",
      "label": "Button Icon Color",
      "default": "#000000"
    },
    {
      "type": "checkbox",
      "id": "show_on_product_page",
      "label": "Show on Product Page",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_collection_page",
      "label": "Show on Collection Page",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_pages",
      "label": "Show on Pages",
      "default": true
    }
  ]
}
{% endschema %}
