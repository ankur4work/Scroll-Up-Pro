{%render 'meroxio-spin-and-shop'%}
{% schema %}
{
  "name": "Spin And Shop",
  "target": "body",
  "stylesheet": "meroxio-spin-and-shop.css",
  "javascript": "meroxio-spin-and-shop.js",
  "settings": [
    {
      "type": "color",
      "id": "textColor",
      "label": "Color"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "sub_heading",
      "label": "Sub Heading"
    },
    {
      "type": "product",
      "id": "main_product",
      "label": "Main Product"
    },
    {
      "type": "product_list",
      "id": "product1",
      "label": "Product 1"
    }, {
      "type": "product_list",
      "id": "product2",
      "label": "Product 2"
    }, {
      "type": "product_list",
      "id": "product3",
      "label": "Product 3"
    }
  ]
}
{% endschema %}

