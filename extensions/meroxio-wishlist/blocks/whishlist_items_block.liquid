<div class="wishlist-power-by-bar"></div>
<h1 class="wishlist-page-heading">{{ block.settings.wishlist-page-heading }}</h1>

<div id="wishlist-items">
  <!-- Placeholder for dynamic wishlist items -->
</div>

{% schema %}
    {
      "name": "Wishlist items",
      "target": "section",
      "stylesheet": "wishlist_block.css",   
      "settings": [
        {
          "type": "text",
          "id": "wishlist-page-heading",
          "label": "Page heading",
          "default": "Your Wishlist"
        },
        {
          "type": "checkbox",
          "id": "compare-price",
          "label": "Show Compare price"
        },
        {
          "type": "checkbox",
          "id": "floating-button",
          "label": "Show Floting Button"
        }

      ]
    }
{% endschema %}