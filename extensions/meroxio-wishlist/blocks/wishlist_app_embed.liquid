document.addEventListener("DOMContentLoaded", () => {
  const initializeWishlistButton = (button) => {
    console.log("initilaizing:" + button)
    // Prevent duplicate initialization
    if (button.dataset.initialized === "true") return;

    // Mark as initialized
    button.dataset.initialized = "true";

    const productHandle = button.getAttribute("data-product-handle");

    if (!productHandle) {
        console.error("Wishlist button is missing 'data-product-handle'");
        return;
    }

    // Set Initial State
    if (Wishlist.isInWishlist(productHandle)) {
        button.classList.add("wishlist-filled");
    }

    // Ensure no duplicate event listeners
    button.removeEventListener("click", handleWishlistClick); // Clean up first
    button.addEventListener("click", handleWishlistClick);

