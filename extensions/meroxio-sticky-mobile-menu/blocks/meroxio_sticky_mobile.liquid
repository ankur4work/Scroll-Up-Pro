{% if block.settings.display_index %}
    {% if template.name == "index" %}
    {% render "meroxio_sticky_mobile_menu_snippets" %}
    {% endif %}
{% endif %}
{% if block.settings.display_collection %}
    {% if template.name == "collection" %}
    {% render "meroxio_sticky_mobile_menu_snippets" %}
    {% endif %}
{% endif %}
{% if block.settings.display_product %}
    {% if template.name == "product" %}
    {% render "meroxio_sticky_mobile_menu_snippets" %}
    {% endif %}
{% endif %}
{% if block.settings.display_page %}
    {% if template.name == "page" %}
    {% render "meroxio_sticky_mobile_menu_snippets" %}
    {% endif %}
{% endif %}
{% if block.settings.display_cart %}
    {% if template.name == "cart" %}
    {% render "meroxio_sticky_mobile_menu_snippets" %}
    {% endif %}
{% endif %}
{% if template.name == "blog" %}
    {% render "meroxio_sticky_mobile_menu_snippets" %}
    {% endif %}
{% schema %}
  {
    "name": "Mobile Menu[Paid] ",
    "target": "body",
    "stylesheet": "meroxio_sticky_mobile_menu_bar.css",
    "available_if": "{{ app.metafields.meroxio.mobile_menu_premium }}",
    "settings": [
        

        {
            "type": "header",
            "content": "Icon Settings - 1"
        },
        {
            "type": "text",
            "id": "m-icon-text-1",
            "label": "Title",
            "default": "Home"
        },
        {
            "type": "image_picker",
            "id": "m-icon-1",
            "label": "Custom Icon"
        },
        {
            "type": "url",
            "id": "icon_url_1",
            "label": "Link"
        },
        {
            "type": "header",
            "content": "Icon Settings - 2"
        },
        {
            "type": "text",
            "id": "m-icon-text-2",
            "label": "Title",
            "default": "Categories"
        },
        {
            "type": "image_picker",
            "id": "m-icon-2",
            "label": "Custom Icon"
        },
        {
            "type": "url",
            "id": "categories",
            "label": "Link"
        },
        
        {
            "type": "header",
            "content": "Icon Settings - 3"
        },
        {
            "type": "text",
            "id": "m-icon-title-5",
            "label": "Title",
            "default": "Gift"
        },
        {
            "type": "image_picker",
            "id": "m-icon-5",
            "label": "Custom Icon"
        },
        {
            "type": "url",
            "id": "m-icon-link-5",
            "label": "Link"
        },
        {
            "type": "header",
            "content": "Icon Settings -4"
        },
        {
            "type": "text",
            "id": "m-icon-text-5",
            "label": "Title",
            "default": "Cart"
        },
        {
            "type": "image_picker",
            "id": "m-icon-3",
            "label": "Custom Icon"
        },
        {
            "type": "url",
            "id": "m_icon_url-5",
            "label": "Link"
        },
        {
            "type": "header",
            "content": "Icon Settings -5"
        },
        {
            "type": "text",
            "id": "m-icon-text-6",
            "label": "Title",
            "default": "Account"
        },
        {
            "type": "image_picker",
            "id": "m-icon-4",
            "label": "Custom Icon"
        },
        {
            "type": "url",
            "id": "icon_url_6",
            "label": "Link"
        },
        {
            "type": "checkbox",
            "id": "display_index",
            "label": "Show on Home Page",
            "default": true
          },
          {
            "type": "checkbox",
            "id": "display_collection",
            "label": "Show on Collection Page",
            "default": true
          },
          {
            "type": "checkbox",
            "id": "display_product",
            "label": "Show on Product Page",
            "default": true
          },
          {
            "type": "checkbox",
            "id": "display_page",
            "label": "Show on Custom Pages",
            "default": true
          },
          {
            "type": "checkbox",
            "id": "display_cart",
            "label": "Show on Cart Page",
            "default": true
          },
        {
            "type": "header",
            "content": "Design Settings"
        },
        {
            "type": "color",
            "id": "m-background",
            "label": "Background Color",
            "default": "#ffffff"
        },
        {
            "type": "color",
            "id": "m-icon-border-color",
            "label": "Icon Border Color",
            "default": "#000000"
        },
        {
            "type": "range",
            "id": "svg_size",
            "label": "Icon Size",
            "min": 10,
            "max": 50,
            "step": 1,
            "unit": "px",
            "default": 30
          },
          {
            "type": "color",
            "id": "m_text_color",
            "label": "Text Color",
            "default": "#000000"
        },
        {
             "type": "range",
             "id": "m-font",
             "label": "Text Font Size",
             "min": 10,
             "max": 20,
             "step": 1,
             "unit": "px",
             "default": 12
           }
       
    ]
  }
{% endschema %}