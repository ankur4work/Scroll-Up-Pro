{% render "meroxio_sticky_mobile_menu_free_snippets" %}
{% schema %}
  {
    "name": "Mobile Menu[Free]",
    "target": "body",
    "stylesheet": "meroxio_sticky_mobile_free.css",
    "javascript": "meroxio_sticky_mobile_free.js",
    "settings": [
        {
            "type": "header",
            "content": "Icon Settings - 1"
        },
        {
            "type": "text",
            "id": "m-icon-text-1",
            "label": "Name",
            "default": "Home"
        },
        {
            "type": "image_picker",
            "id": "m-icon-1",
            "label": "Icon"
        },
        
        {
            "type": "url",
            "id": "icon_url_1",
            "label": "Link"
        },
        {
            "type": "text",
            "id": "icon-name-1",
            "label": "Icon Name",
            "default": "home-1"
          },
        {
            "type": "header",
            "content": "Icon Settings - 2"
        },
        {
            "type": "text",
            "id": "m-icon-text-2",
            "label": "Name",
            "default": "Categories"
        },
        {
            "type": "image_picker",
            "id": "m-icon-2",
            "label": "Icon"
        },
        
        {
            "type": "url",
            "id": "categories",
            "label": "Link"
        },
        
        {
            "type": "header",
            "content": "Icon Settings - 3"
        },
        {
            "type": "text",
            "id": "m-icon-title-5",
            "label": "Name",
            "default": "Gift"
        },
        {
            "type": "image_picker",
            "id": "m-icon-5",
            "label": "Icon"
        },
        {
            "type": "url",
            "id": "m-icon-link-5",
            "label": "Link"
        },
        {
            "type": "header",
            "content": "Icon Settings - 4"
        },
        {
            "type": "text",
            "id": "m-icon-text-5",
            "label": "Name",
            "default": "Cart"
        },
        {
            "type": "image_picker",
            "id": "m-icon-3",
            "label": "Icon"
        },
        {
            "type": "url",
            "id": "m_icon_url-5",
            "label": "Link"
        },
        {
            "type": "header",
            "content": "Icon Settings -5"
        }, 
        {
            "type": "text",
            "id": "m-icon-text-6",
            "label": "Name",
            "default": "User"
        },
        {
            "type": "image_picker",
            "id": "m-icon-4",
            "label": "Icon"
        },
        {
            "type": "url",
            "id": "icon_url_6",
            "label": "Link"
        },

        {
            "type": "header",
            "content": "Design Settings"
        },
        {
            "type": "range",
            "id": "svg_size",
            "label": "Icon Size",
            "min": 10,
            "max": 50,
            "step": 1,
            "unit": "px",
            "default": 30
          },

        
        {
            "type": "color",
            "id": "m_text_color",
            "label": "Text Color",
            "default": "#000000"
        },
        
        {
             "type": "range",
             "id": "m-font",
             "label": "Text Font Size",
             "min": 10,
             "max": 20,
             "step": 1,
             "unit": "px",
             "default": 12
           }
       
    ]
  }
{% endschema %}