{% render "meroxio_sticky_mobile_menu_free_snippets" %}
{% schema %}
  {
    "name": "Sticky Mobile Bar Free",
    "target": "body",
    "stylesheet": "meroxio_sticky_mobile_free.css",
    "settings": [
        
        
        {
            "type": "header",
            "content": "Icon Settings - 1"
        },
        
        {
            "type": "checkbox",
            "id": "show-home",
            "label": "Show Icon",
            "default": true
        },
        {
            "type": "image_picker",
            "id": "m-icon-1",
            "label": "Icon"
        },
        {
            "type": "text",
            "id": "m-icon-text-1",
            "label": "Name",
            "default": "Home"
        },
        {
            "type": "url",
            "id": "icon_url_1",
            "label": "Link"
        },
        {
            "type": "header",
            "content": "Icon Settings - 2"
        },
        
        {
            "type": "checkbox",
            "id": "show-categories",
            "label": "Show Icon",
            "default": true
        },
    
        
        {
            "type": "image_picker",
            "id": "m-icon-2",
            "label": "Icon"
        },
        {
            "type": "text",
            "id": "m-icon-text-2",
            "label": "Name",
            "default": "Categories"
        },
        
        {
            "type": "url",
            "id": "categories",
            "label": "Link"
        },
        
        {
            "type": "header",
            "content": "Icon Settings - 3"
        },
        
        {
            "type": "checkbox",
            "id": "show-custom-icon-1",
            "label": "Show Icon ",
            "default": true
        },
        {
            "type": "image_picker",
            "id": "m-icon-5",
            "label": "Icon"
        },
        {
            "type": "text",
            "id": "m-icon-title-5",
            "label": "Name",
            "default": "Gift"
        },
        {
            "type": "url",
            "id": "m-icon-link-5",
            "label": "Link"
        },
        {
            "type": "header",
            "content": "Icon Settings - 4"
        },
        
        {
            "type": "checkbox",
            "id": "show-cart",
            "label": "Show Icon",
            "default": true
        },
        
        {
            "type": "image_picker",
            "id": "m-icon-3",
            "label": "Icon"
        },
        {
            "type": "text",
            "id": "m-icon-text-5",
            "label": "Name",
            "default": "Cart"
        },
        {
            "type": "url",
            "id": "m_icon_url-5",
            "label": "Link"
        },
        {
            "type": "header",
            "content": "Icon Settings -5"
        },
        
        {
            "type": "checkbox",
            "id": "show-account",
            "label": "Show Icon",
            "default": true
        },
        
        {
            "type": "image_picker",
            "id": "m-icon-4",
            "label": "Icon"
        },
        {
            "type": "text",
            "id": "m-icon-text-6",
            "label": "Name",
            "default": "Name"
        },
        {
            "type": "url",
            "id": "icon_url_6",
            "label": "Link"
        },

        {
            "type": "header",
            "content": "Design Settings"
        },
        {
            "type": "color",
            "id": "svg_color",
            "label": "Icon Color",
            "default": "#000000"
        },
        {
            "type": "range",
            "id": "svg_size",
            "label": "Icon Size",
            "min": 10,
            "max": 40,
            "step": 1,
            "unit": "px",
            "default": 16
          },

        
        {
            "type": "color",
            "id": "m_text_color",
            "label": "Text Color",
            "default": "#000000"
        },
        
        {
             "type": "range",
             "id": "m-font",
             "label": "Text Font Size",
             "min": 10,
             "max": 20,
             "step": 1,
             "unit": "px",
             "default": 12
           }
       
    ]
  }
{% endschema %}